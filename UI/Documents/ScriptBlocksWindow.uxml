<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Packages/de.codesmile.lunyscript/LunyScript.Unity/UI/Documents/ScriptBlocksWindow.uss?fileID=7433441132597879392&amp;guid=a802f3de1cf6437ab806f4c65243e84d&amp;type=3#ScriptBlocksWindow"/>
    <ui:VisualElement name="root" style="flex-grow: 1; flex-direction: column;">
        <ui:VisualElement name="toolbar" style="flex-direction: row;">
            <ui:TextField name="filter-field" placeholder-text="Filter by block name..." style="flex-grow: 1;"/>
            <ui:Toggle name="toggle-show-empty" label="Show Empty"/>
        </ui:VisualElement>
        <ui:TreeView name="blocks-tree" fixed-item-height="22" style="flex-grow: 1;"/>
        <ui:Label name="empty-label" text="Not in PlayMode" style="display: none;"/>
    </ui:VisualElement>
</ui:UXML>
