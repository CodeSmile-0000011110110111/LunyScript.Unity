@import url("DiagnosticsWindowStyles.uss");

/* Constant variable rows: subtle warm-amber background */
.constant-row {
    background-color: rgba(200, 150, 40, 0.12);
}

/* Name and timestamp cells are read-only — suppress pointer interaction */
.name-cell,
.timestamp-cell {
    pointer-events: none;
}

/* This targets the RadioButtonGroup to get horizontal layout */
.unity-radio-button-group__container {
    flex-direction: row;
}
